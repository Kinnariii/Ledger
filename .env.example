# ── Database ──────────────────────────────────────────────────────────────────
# Connection string for your PostgreSQL instance (e.g. Neon Cloud Postgres)
DATABASE_URL="postgresql://username:password@ep-host.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Authentication ───────────────────────────────────────────────────────────
# Google OAuth 2.0 Credentials (obtain from Google Cloud Console)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret-gocspx"

# Public URL of the application (used for redirects and callback URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# HS256 JWT signing secret (minimum 32 characters recommended)
JWT_SECRET="generate-a-secure-random-32-character-secret-key"

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Google AI Studio API Key (obtain from aistudio.google.com)
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# Gemini Model selection (e.g. gemini-flash-latest or gemini-2.0-flash)
GEMINI_MODEL="gemini-flash-latest"

# ── WhatsApp Integration ──────────────────────────────────────────────────────
# Provider selection: "mock" (persists to local DB) or "meta" (real Meta API calls)
WHATSAPP_PROVIDER="mock"

# Meta WhatsApp Webhook Verify Token (used to match Facebook challenge requests)
WHATSAPP_VERIFY_TOKEN="ledger_verify_token_default"

# [Meta API Only] WhatsApp Access Token (obtained from Meta App developer portal)
WHATSAPP_ACCESS_TOKEN="EAAG..."

# [Meta API Only] Phone Number ID associated with your business WhatsApp Cloud account
WHATSAPP_PHONE_NUMBER_ID="1234567890"
